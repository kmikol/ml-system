// Grafana Alloy configuration
// Scrapes metrics from the serving service and remote-writes to Prometheus.
// To add Loki log collection later, add a loki.source.* component here.

prometheus.scrape "serving" {
  targets = [
    {"__address__" = "serving:8000", "__metrics_path__" = "/metrics"},
  ]
  scrape_interval = "10s"
  forward_to      = [prometheus.remote_write.local.receiver]
}

prometheus.remote_write "local" {
  endpoint {
    url = "http://prometheus:9090/api/v1/write"
  }
}
